http://localhost {
  redir https://localhost{uri} permanent
}

https://localhost {
  tls internal
  encode gzip zstd

  @backend path /api/* /docs* /error
  handle @backend {
    reverse_proxy backend-primary:8000 backend-secondary:8000 {
      lb_policy first
      health_uri /api/health
      health_interval 10s
      health_timeout 3s
      health_fails 1
      health_passes 1
    }
  }

  handle {
    root * /srv
    try_files {path} /index.html
    file_server
  }
}
