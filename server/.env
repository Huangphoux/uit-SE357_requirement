# Server
APP_HOST=localhost
APP_PORT=8000

# Database (SQLite)
DATABASE_URL="file:./dev.db?socket_timeout=10000"

# JWT Authentication
AUTH_SECRET="your_jwt_access_token_secret"
AUTH_SECRET_EXPIRES_IN="24h"
AUTH_REFRESH_SECRET="your_jwt_refresh_token_secret"
AUTH_REFRESH_SECRET_EXPIRES_IN=180000000

# Email (Optional)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your_email@gmail.com"
EMAIL_PASSWORD="your_app_password"

# Node Environment
NODE_ENV=development

# Redis 
REDIS_HOST=localhost # Change to your Redis server host if not running locally
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX=5 # Max 5 requests per window per IP

# Lockout settings
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MS=900000 # 15 minutes

# Audit logging
AUDIT_LOG_DIR=./logs/audit
AUDIT_RETENTION_DAYS=365