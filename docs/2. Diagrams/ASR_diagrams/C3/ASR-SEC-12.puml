@startuml ASR-SEC-12
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title ASR-SEC-12: Secure File Upload with Malware Scanning\n100% Malware Scanning and Whitelist File Type Validation

Person(teacher, "Teacher", "Uploads course materials")
Person(student, "Student", "Submits assignment files")
Person(attacker, "Attacker", "Attempts to upload malware")

System_Boundary(lms, "LMS System") {

    Container(clientApp, "Client Application", "React + TypeScript", "File upload form UI")

    Container_Boundary(apiServer, "API Server [Express.js + Node.js]") {
        Component(fileReceiver, "File Receiver", "Service", "Receives file from client via HTTP POST")
        Component(uploadOrchestrator, "Upload Orchestrator", "Service", "Coordinates validation, scanning, and storage")
        Component(fileMetaExtractor, "File Metadata Extractor", "Service", "Extracts filename, size, MIME type")
    }

    Container_Boundary(fileTypeValidator, "File Type Validator [Validation Service]") {
        Component(extensionChecker, "Extension Checker", "Service", "Validates file extension (e.g., .pdf, .docx, .jpg)")
        Component(mimeTypeValidator, "MIME Type Validator", "Service", "Validates Content-Type header matches extension")
        Component(magicNumberDetector, "Magic Number Detector", "Service", "Reads file magic bytes to detect actual file type")
        Component(whitelist, "Whitelist", "Service", "Allowed types: pdf, doc, docx, xls, xlsx, jpg, png, zip")
    }

    Container_Boundary(fileSizeValidator, "File Size Validator [Size Checking]") {
        Component(sizeLimiter, "Size Limiter", "Service", "Materials: max 50MB, Submissions: max 20MB")
    }

    Container_Boundary(malwareScanner, "Malware Scanner [ClamAV / Third-Party Service]") {
        Component(scanEngine, "Scan Engine", "Service", "Scans file for known malware signatures")
        Component(threatDatabase, "Threat Database", "Service", "Updated virus definitions (daily updates)")
        Component(behavioralAnalyzer, "Behavioral Analyzer", "Service", "Detects suspicious file behavior patterns")
        Component(quarantineHandler, "Quarantine Handler", "Service", "Quarantines infected files separately")
    }

    Container_Boundary(fileStorage, "File Storage [Secure File Storage]") {
        Component(safeStorageLocation, "Safe Storage Location", "Service", "Files stored in /uploads/ outside /public/")
        Component(accessController, "Access Controller", "Service", "Restricts direct file access via web server")
        Component(filePermissions, "File Permissions", "Service", "Files readable by app server, not world-readable")
    }

    Container_Boundary(auditLog, "Audit Log [Database]") {
        Component(uploadLog, "Upload Log", "DB", "user_id, filename, file_size, file_type, timestamp, ip")
        Component(malwareScanLog, "Malware Scan Log", "DB", "Logs scan results, threats detected, quarantine actions")
        Component(rejectionLog, "Rejection Log", "DB", "Logs rejected files (invalid type, size, infected)")
    }

    Container(alertingService, "Alerting Service", "Monitoring", "Alerts on malware detection or suspicious uploads")
}

Rel(fileReceiver, uploadOrchestrator, "Received file")
Rel(uploadOrchestrator, fileMetaExtractor, "Extract metadata")
Rel(extensionChecker, mimeTypeValidator, "Check extension")
Rel(mimeTypeValidator, magicNumberDetector, "Validate MIME")
Rel(magicNumberDetector, whitelist, "Check against whitelist")
Rel(scanEngine, threatDatabase, "Check signatures")
Rel(scanEngine, behavioralAnalyzer, "Analyze behavior")
Rel(behavioralAnalyzer, quarantineHandler, "Quarantine if infected")
Rel(safeStorageLocation, accessController, "Control access")
Rel(accessController, filePermissions, "Set permissions")
Rel(malwareScanLog, uploadLog, "Log all uploads")
Rel(rejectionLog, uploadLog, "Log rejections")
Rel(teacher, clientApp, "Upload course material (PDF, DOCX)")
Rel(clientApp, apiServer, "POST /upload {file}")
Rel(apiServer, fileTypeValidator, "Validate file type")
Rel(fileTypeValidator, fileSizeValidator, "Check size (if type valid)")
Rel(fileSizeValidator, malwareScanner, "Scan for malware (if size valid)")
Rel(malwareScanner, fileStorage, "Store if clean")
Rel(fileStorage, auditLog, "Log successful upload")
Rel(fileStorage, clientApp, "Return upload success")
Rel(student, clientApp, "Submit assignment (ZIP with code)")
Rel(apiServer, fileSizeValidator, "Check size")
Rel(attacker, clientApp, "Upload malware-infected EXE")
Rel(apiServer, fileTypeValidator, "Validate: .exe not in whitelist")
Rel(fileTypeValidator, clientApp, "403 Forbidden - Invalid file type")
Rel(malwareScanner, auditLog, "Log quarantine: malware detected")
Rel(malwareScanner, alertingService, "Alert: malware detected")

@enduml
