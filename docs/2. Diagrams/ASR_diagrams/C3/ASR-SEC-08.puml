@startuml ASR-SEC-08
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title ASR-SEC-08: Input Validation and Sanitization\n100% Input Validation Before Processing

Person(user, "User", "Submits form data")
Person(attacker, "Attacker", "Attempts malicious input (XSS, injection)")

System_Boundary(lms, "LMS System") {

    Container_Boundary(clientApp, "Client Application [React + TypeScript]") {
        Component(textInput, "Text Input Field", "UI", "Captures user text input")
        Component(emailInput, "Email Input Field", "UI", "Captures email addresses")
        Component(numberInput, "Number Input Field", "UI", "Captures numeric values")
        Component(fileInput, "File Input Field", "UI", "Captures file uploads")
        Component(clientValidator, "Client Validator", "UI", "Real-time validation (format, length, type)")
    }

    Container_Boundary(apiServer, "API Server [Express.js + Node.js]") {
        Component(inputReceiver, "Input Receiver", "Service", "Receives form data, file uploads, JSON payloads")
        Component(schemaValidator, "Schema Validator", "Service", "Validates input against JSON schema (joi, zod)")
        Component(typeValidator, "Type Validator", "Service", "Ensures correct data types (string, number, boolean)")
        Component(formatValidator, "Format Validator", "Service", "Validates specific formats (email, URL, phone, date)")
        Component(lengthValidator, "Length Validator", "Service", "Validates min/max length for strings")
        Component(rangeValidator, "Range Validator", "Service", "Validates min/max values for numbers")
        Component(fileValidator, "File Validator", "Service", "Validates file type, size, extension whitelist")
        Component(sanitizer, "Sanitizer", "Service", "Removes/escapes potentially harmful content")
        Component(requestLogger, "Request Logger", "Service", "Logs all input validation results")
    }

    ContainerDb(database, "Database", "PostgreSQL", "Only stores validated/sanitized data")

    Container_Boundary(validationErrHandler, "Validation Error Handler [Error Response Service]") {
        Component(errorFormatter, "Error Formatter", "Service", "Formats validation error messages")
        Component(errorLogger, "Error Logger", "Service", "Logs validation failures for security analysis")
    }

    Container_Boundary(securityAuditLog, "Security Audit Log [Database]") {
        Component(validationFailLog, "Validation Failure Log", "DB", "user_id, input, validation_rule_failed, timestamp")
        Component(sqlInjectionAttempts, "SQL Injection Attempts", "DB", "Logs attempts to inject SQL code")
        Component(xssAttempts, "XSS Attempts", "DB", "Logs attempts to inject scripts")
        Component(pathTraversalAttempts, "Path Traversal Attempts", "DB", "Logs attempts to access unauthorized files")
    }

    Container(alertingService, "Alerting Service", "Monitoring", "Alerts on repeated validation failures (possible attacks)")
}

Rel(textInput, clientValidator, "Validate on input")
Rel(emailInput, clientValidator, "Validate format")
Rel(numberInput, clientValidator, "Validate range")
Rel(fileInput, clientValidator, "Validate file type/size")
Rel(inputReceiver, schemaValidator, "Validate schema")
Rel(schemaValidator, typeValidator, "Check types")
Rel(typeValidator, formatValidator, "Validate formats")
Rel(formatValidator, lengthValidator, "Check length")
Rel(lengthValidator, rangeValidator, "Check range")
Rel(rangeValidator, fileValidator, "Validate files")
Rel(fileValidator, sanitizer, "Sanitize input")
Rel(sanitizer, requestLogger, "Log validation result")
Rel(errorFormatter, errorLogger, "Log error")
Rel(sqlInjectionAttempts, validationFailLog, "Log SQL injection")
Rel(xssAttempts, validationFailLog, "Log XSS")
Rel(pathTraversalAttempts, validationFailLog, "Log path traversal")
Rel(user, clientApp, "Enter form data")
Rel(clientApp, apiServer, "POST /api/submit {data}")
Rel(apiServer, database, "Only INSERT validated data")
Rel(attacker, clientApp, "Attempt malicious input (XSS, SQL injection, etc.)")
Rel(apiServer, validationErrHandler, "Input validation failed")
Rel(validationErrHandler, clientApp, "400 Bad Request + error message")
Rel(apiServer, securityAuditLog, "Log validation failure")
Rel(securityAuditLog, alertingService, "Alert on repeated attacks from same IP/user")

@enduml
