# Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (PostgreSQL)
# For local development: localhost:5432
# For Docker Compose: db:5432
POSTGRES_DB=uit_se357
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL="postgresql://postgres:postgres@db:5432/uit_se357?schema=public"

# JWT Authentication
AUTH_SECRET="your_jwt_access_token_secret"
AUTH_SECRET_EXPIRES_IN="24h"
AUTH_REFRESH_SECRET="your_jwt_refresh_token_secret"
AUTH_REFRESH_SECRET_EXPIRES_IN=180000000

# Email Configuration (Optional)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your_email@gmail.com"
EMAIL_PASSWORD="your_app_password"

# Environment
NODE_ENV=development

# Redis Configuration
# For local development: localhost:6379
# For Docker Compose: redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_MAX=100 # Max 100 requests per window per IP

# Account Lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MS=900000 # 15 minutes

# Audit Logging
AUDIT_LOG_DIR=./logs/audit
AUDIT_RETENTION_DAYS=365

# Web (Frontend) Port
WEB_PORT=80
